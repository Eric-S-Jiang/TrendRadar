# ============================================================
# GPXX V3 后端 — 生产部署环境变量
# 用法（服务器）：cp deploy/.env.example deploy/.env  填入真实值
# ============================================================

# —— Redis（至少 24 字符强密码） ——
REDIS_PASSWORD=

# —— JWT（必填，openssl rand -hex 32 生成） ——
JWT_SECRET=

# —— DeepSeek ——
DEEPSEEK_API_KEY=

# —— CORS（生产域名/IP，逗号分隔；Nginx 80 端口不写端口号） ——
CORS_ORIGINS=http://8.159.159.48

# —— 可选 ——
LOG_LEVEL=INFO
SSE_MAX_CONNECTIONS=100
GUEST_MODE_ENABLED=true
