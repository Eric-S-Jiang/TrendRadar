# ============================================================
# GPXX V3 生产环境变量模板
# 复制为 .env.production 并填写所有 REPLACE_WITH_* 项
# ============================================================

# JWT — 必须替换！生成命令：openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Redis 密码 — 必须替换！
REDIS_PASSWORD=REPLACE_WITH_strong_password

# DeepSeek API Key
DEEPSEEK_API_KEY=

# CORS — 前端访问的域名/IP，逗号分隔，无末尾斜杠
CORS_ORIGINS=http://8.159.159.48

# 日志级别
LOG_LEVEL=INFO

# SSE 最大连接数
SSE_MAX_CONNECTIONS=100

# 游客模式（无需登录可访问只读接口）
GUEST_MODE_ENABLED=true
