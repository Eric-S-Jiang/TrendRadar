# ============================================================
# GPXX V3 后端 — 开发环境变量示例
# 用法：cp .env.example .env  然后填入真实值
# 注意：.env 已在 .gitignore 中，不会提交
# ============================================================

# —— 数据库（开发期用本地相对路径，生产用容器内绝对路径） ——
DATABASE_URL=sqlite+aiosqlite:///./data/gpxx.db
TREND_DATABASE_URL=sqlite+aiosqlite:///./data/trend.db

# —— Redis（开发期用 docker 起一个：
#       docker run -d --name dev-redis -p 6379:6379 redis:7-alpine --requirepass devpass ） ——
REDIS_URL=redis://:devpass@localhost:6379/0

# —— JWT（用 openssl rand -hex 32 生成；开发期可用任意 32+ 字符） ——
JWT_SECRET=dev-only-please-replace-with-openssl-rand-hex-32

# —— DeepSeek ——
DEEPSEEK_API_KEY=sk-your-key-here

# —— CORS（前端 vite 默认 5173） ——
CORS_ORIGINS=http://localhost:5173

# —— TrendRadar 配置文件路径 ——
TRENDRADAR_CONFIG_PATH=./config/config.yaml

# —— 日志 ——
LOG_LEVEL=DEBUG

# —— SSE ——
SSE_MAX_CONNECTIONS=100

# —— 游客模式 ——
GUEST_MODE_ENABLED=true
